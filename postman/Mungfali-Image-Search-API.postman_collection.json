{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Mungfali Image Search API",
    "description": "Official Postman collection for the Mungfali Image Search API.\n\n## Setup\n1. Import this file in Postman (**Import** → select this JSON).\n2. Open the collection → **Variables** tab.\n3. Set `api_key` to your key from https://mungfali.net/dashboard (prefix `mng_`).\n4. Save — Bearer auth uses `{{api_key}}` automatically.\n\nNo pagination: each search returns up to 150 images in one response.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_key}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://mungfali.net"
    },
    {
      "key": "api_key",
      "value": "",
      "type": "secret"
    }
  ],
  "item": [
    {
      "name": "Search",
      "item": [
        {
          "name": "Search images (basic)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/search?q=electric+car",
              "host": ["{{base_url}}"],
              "path": ["v1", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "electric car",
                  "description": "Required search query"
                }
              ]
            },
            "description": "Basic image search with required parameter `q`. Returns up to 150 images — no pagination."
          },
          "response": []
        },
        {
          "name": "Search images (count=150)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/search?q=mountain+landscape&count=150",
              "host": ["{{base_url}}"],
              "path": ["v1", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "mountain landscape"
                },
                {
                  "key": "count",
                  "value": "150",
                  "description": "Max images (1-150)"
                }
              ]
            },
            "description": "Explicit count parameter (optional; default is 150)."
          },
          "response": []
        },
        {
          "name": "Search images (SafeSearch strict)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/search?q=office+workspace&safeSearch=strict&filterTransparent=true",
              "host": ["{{base_url}}"],
              "path": ["v1", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "office workspace"
                },
                {
                  "key": "safeSearch",
                  "value": "strict"
                },
                {
                  "key": "filterTransparent",
                  "value": "true"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Errors (examples)",
      "item": [
        {
          "name": "Missing query (400)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{api_key}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/search",
              "host": ["{{base_url}}"],
              "path": ["v1", "search"]
            },
            "description": "Demonstrates invalid_request when `q` is omitted."
          },
          "response": []
        },
        {
          "name": "Invalid API key (401)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "mng_invalid_key",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/search?q=test",
              "host": ["{{base_url}}"],
              "path": ["v1", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "test"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
